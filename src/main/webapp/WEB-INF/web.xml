<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <context-param>
        <param-name>db.jdbcUrl</param-name>
        <param-value>jdbc:postgresql://postgres:5432/cms_db</param-value>
    </context-param>

    <context-param>
        <param-name>db.username</param-name>
        <param-value>cms_user</param-value>
    </context-param>

    <context-param>
        <param-name>db.password</param-name>
        <param-value>cms_pw</param-value>
    </context-param>

    <listener>
        <listener-class>hu.laci.cms.backend.config.DatabaseConfigListener</listener-class>
    </listener>

</web-app>
